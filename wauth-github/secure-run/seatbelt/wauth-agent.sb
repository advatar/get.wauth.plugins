;; wauth-agent.sb — WAUTH secure-run Tier A (macOS Seatbelt, no Docker).
;;
;; Goal: run a coding agent (Codex / Claude Code) directly on macOS while making the host's
;; personal credential stores UNREADABLE to it — so a prompt-injected or hostile agent cannot
;; exfiltrate ~/.ssh, the gh token, ~/.aws, etc. The doorkeeper (Tier C) remains the only
;; sanctioned path to a protected write; this profile removes the agent's ability to *read* the
;; ambient keys that would otherwise let it go around the doorkeeper.
;;
;; DESIGN — default-deny-READ scoped to $HOME, not to "/".
;;   Seatbelt's network/system plumbing on modern macOS depends on a large, undocumented set of
;;   mach services + file reads. A from-scratch "(deny default)" profile reliably breaks outbound
;;   networking (the documented Seatbelt rabbit hole). So we keep "(allow default)" — which inherits
;;   the working network/system plumbing — and then DEFAULT-DENY READS *inside the home directory*,
;;   re-allowing only the workspace, the agent's own dirs, and the (non-credential) dev toolchains.
;;   Personal credentials live in $HOME, so scoping the blanket read-deny to $HOME is the right
;;   granularity: it FAILS CLOSED — an unknown dotfile under $HOME is denied until explicitly allowed,
;;   which a deny-list of named secret paths can never guarantee.
;;
;;   Trade-off, stated honestly: the re-allow list below enumerates dev TOOLCHAIN dirs (no secrets).
;;   If your agent or a tool is installed somewhere under $HOME not listed here, it will get a
;;   read error — that is the fail-closed direction (a functionality gap, never a silent exposure).
;;   Add the dir to the re-allow block. Never add a credential dir (~/.ssh, ~/.aws, ~/.config/gh,
;;   ~/.gnupg, ~/.kube, ~/.azure, ~/.config/gcloud, ~/.git-credentials, ~/Library/Keychains) — those
;;   are the whole point.
;;
;; This is the neko-kai/claude-code-sandbox "noread" model (default-deny-read + allow-list) made
;; network-robust. Egress allow-listing is layered separately via HTTPS_PROXY (see
;; secure-run-seatbelt.sh), mirroring michaelneale/agent-seatbelt-sandbox.
;;
;; Params (supplied by secure-run-seatbelt.sh via -D): HOME (absolute), WORKSPACE (resolved realpath).
;;
;; NOTE: sandbox-exec(1) is deprecated-but-functional; SBPL is reverse-engineered and can shift
;; between macOS releases. Tier A is the frictionless, semi-trusted tier. For a hostile agent assume
;; Tier B (container) or Tier C (doorkeeper — the credential is never on the box at all).

(version 1)
(allow default)

;; (1) Default-DENY reads inside the home directory — catches every credential under $HOME,
;;     including ones not enumerated anywhere.
(deny file-read* file-read-metadata (subpath (param "HOME")))

;; (2) Re-allow reads of the workspace, the agent's own state, and NON-CREDENTIAL dev toolchains.
;;     (string-append keeps this self-contained: only HOME + WORKSPACE need to be passed in.)
(allow file-read* file-read-metadata
  (subpath (param "WORKSPACE"))
  ;; the agent's own cognition-credential / session-state dirs
  (subpath (string-append (param "HOME") "/.codex"))
  (subpath (string-append (param "HOME") "/.claude"))
  ;; node / package toolchains (program files + caches, no secrets)
  (subpath (string-append (param "HOME") "/.nvm"))
  (subpath (string-append (param "HOME") "/.npm"))
  (subpath (string-append (param "HOME") "/.npm-global"))
  (subpath (string-append (param "HOME") "/.node-gyp"))
  (subpath (string-append (param "HOME") "/.bun"))
  (subpath (string-append (param "HOME") "/.deno"))
  (subpath (string-append (param "HOME") "/.yarn"))
  (subpath (string-append (param "HOME") "/.pnpm"))
  ;; other common language toolchains
  (subpath (string-append (param "HOME") "/.cargo"))
  (subpath (string-append (param "HOME") "/.rustup"))
  (subpath (string-append (param "HOME") "/.pyenv"))
  (subpath (string-append (param "HOME") "/.rbenv"))
  (subpath (string-append (param "HOME") "/.asdf"))
  (subpath (string-append (param "HOME") "/.volta"))
  (subpath (string-append (param "HOME") "/.go"))
  ;; generic XDG-ish caches / state / user binaries (no secrets live here)
  (subpath (string-append (param "HOME") "/.cache"))
  (subpath (string-append (param "HOME") "/.local"))
  ;; git commit identity (NOT ~/.config/git — that can hold a credentials store)
  (literal (string-append (param "HOME") "/.gitconfig")))

;; (3) Defense-in-depth: even though these are now unreadable, also DENY WRITES to the clearest
;;     persistence / key-planting vectors, so a hostile agent cannot append an authorized_key or
;;     drop a login item / shell hook. (Tier A's primary job is read-exfil prevention; this closes
;;     the cheapest write-persistence paths without a blanket home write-deny that would break the agent.)
(deny file-write*
  (subpath (string-append (param "HOME") "/.ssh"))
  (subpath (string-append (param "HOME") "/Library/LaunchAgents"))
  (literal (string-append (param "HOME") "/.zshrc"))
  (literal (string-append (param "HOME") "/.zprofile"))
  (literal (string-append (param "HOME") "/.bashrc"))
  (literal (string-append (param "HOME") "/.bash_profile"))
  (literal (string-append (param "HOME") "/.profile")))
